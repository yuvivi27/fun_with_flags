rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Migration-safe rules: readable leaderboard, constrained writes only to
    // the matching player doc with expected field shape/types.
    match /players/{playerId} {
      allow read: if true;
      allow create, update: if
        request.resource.data.keys().hasOnly([
          'userId',
          'email',
          'username',
          'totalXP',
          'currentLevel',
          'updatedAt'
        ]) &&
        request.resource.data.userId == playerId &&
        request.resource.data.email is string &&
        request.resource.data.username is string &&
        request.resource.data.totalXP is int &&
        request.resource.data.totalXP >= 0 &&
        request.resource.data.currentLevel is int &&
        request.resource.data.currentLevel >= 1;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
