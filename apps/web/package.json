{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "flags:build-db": "node ./scripts/build-flags-database.mjs && node ./scripts/add-advanced-flag-pack.mjs",
    "flags:build-db:base": "node ./scripts/build-flags-database.mjs",
    "flags:add-advanced": "node ./scripts/add-advanced-flag-pack.mjs",
    "flags:sync": "node ./scripts/sync-flags.mjs",
    "flags:sync-us-states": "node ./scripts/sync-us-state-flags.mjs",
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "check-types": "next typegen && tsc --noEmit",
    "build:static": "pnpm run build",
    "android:sync": "pnpm exec cap sync android",
    "android:apk-debug": "pnpm build && pnpm exec cap sync android && cd android && gradlew.bat assembleDebug",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@capacitor/android": "8.3.0",
    "@capacitor/cli": "8.3.0",
    "@capacitor/core": "8.3.0",
    "@repo/player-leveling": "workspace:*",
    "firebase": "^12.11.0",
    "next": "16.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "flag-icons": "^7.5.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.2",
    "vitest": "^3.2.4",
    "world-countries": "^5.1.0"
  }
}
