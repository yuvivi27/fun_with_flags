{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/../tsconfig.spec.json"
      }
    ]
  },
  "moduleNameMapper": {
    "^@repo/player-leveling$": "<rootDir>/../src/test-support/player-leveling-bridge.ts",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
